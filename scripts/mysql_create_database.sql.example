-- Ejemplo local para crear la base de datos de PRESUPUESTO GASTOS.
-- Reemplazar CAMBIAR_PASSWORD_LOCAL en el entorno local.
-- No subir backend/.env con contrasenas reales.

CREATE DATABASE presupuesto_gastos_db
CHARACTER SET utf8mb4
COLLATE utf8mb4_unicode_ci;

CREATE USER 'presupuesto_user'@'localhost'
IDENTIFIED BY 'CAMBIAR_PASSWORD_LOCAL';

GRANT ALL PRIVILEGES ON presupuesto_gastos_db.* TO 'presupuesto_user'@'localhost';

FLUSH PRIVILEGES;
